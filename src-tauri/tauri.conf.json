{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Axon",
  "version": "0.1.0",
  "identifier": "com.marcelgast.axon",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Axon",
        "width": 960,
        "height": 680,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/docker-compose.yml": "docker-compose.yml"
    },
    "category": "Utility",
    "shortDescription": "Secure AI agent orchestration"
  }
}
